<%- include('../partials/head') %>

<style>
  .pdf-editor-container {
    display: flex;
    gap: 16px;
    height: calc(100vh - 140px);
  }

  .signature-panel {
    width: 250px;
    flex-shrink: 0;
    overflow-y: auto;
    border: 1px solid #dee2e6;
    border-radius: 8px;
    background: #fff;
    padding: 12px;
  }

  .signature-panel h6 {
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid #dee2e6;
  }

  .sig-item {
    border: 2px solid #dee2e6;
    border-radius: 6px;
    padding: 8px;
    margin-bottom: 10px;
    cursor: grab;
    text-align: center;
    background: #fff;
    transition: border-color 0.2s;
  }

  .sig-item:hover {
    border-color: #0d6efd;
  }

  .sig-item.selected {
    border-color: #0d6efd;
    box-shadow: 0 0 0 2px rgba(13, 110, 253, 0.25);
  }

  .sig-item img {
    max-width: 100%;
    height: 50px;
    object-fit: contain;
  }

  .sig-item .sig-name {
    font-size: 11px;
    color: #666;
    margin-top: 4px;
  }

  .pdf-viewer-area {
    flex: 1;
    overflow-y: auto;
    border: 1px solid #dee2e6;
    border-radius: 8px;
    background: #808080;
    padding: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .pdf-page-wrapper {
    position: relative;
    background: #fff;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }

  .pdf-page-wrapper canvas {
    display: block;
  }

  .placed-signature {
    position: absolute;
    border: 2px dashed rgba(13, 110, 253, 0.6);
    cursor: move;
    background: transparent;
  }

  .placed-signature img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
  }

  .placed-signature .resize-handle {
    position: absolute;
    width: 12px;
    height: 12px;
    background: #0d6efd;
    border: 1px solid #fff;
    border-radius: 2px;
    bottom: -6px;
    right: -6px;
    cursor: nwse-resize;
  }

  .placed-signature .remove-btn {
    position: absolute;
    top: -10px;
    right: -10px;
    width: 20px;
    height: 20px;
    background: #dc3545;
    color: #fff;
    border: none;
    border-radius: 50%;
    font-size: 12px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .toolbar {
    background: #fff;
    padding: 10px 16px;
    border-bottom: 1px solid #dee2e6;
    display: flex;
    align-items: center;
    gap: 12px;
  }
</style>

<nav class="navbar navbar-dark bg-dark">
  <div class="container-fluid">
    <a class="navbar-brand" href="/">Signature Taker</a>
    <div>
      <a href="/pdf/upload" class="btn btn-outline-light btn-sm me-2">Upload Another PDF</a>
      <a href="/signatures" class="btn btn-outline-light btn-sm">All Signatures</a>
    </div>
  </div>
</nav>

<div class="toolbar">
  <span class="text-muted">Click a signature from the panel, then click on the PDF page to place it.</span>
  <button class="btn btn-success btn-sm ms-auto" id="generate-btn">
    Save & Generate PDF
  </button>
</div>

<div class="container-fluid px-3 py-3">
  <div class="pdf-editor-container">
    <div class="signature-panel">
      <h6>Your Signatures</h6>
      <% if (signatures.length === 0) { %>
        <p class="text-muted small">No signatures yet. <a href="/">Create one</a> first.</p>
      <% } else { %>
        <% signatures.forEach((sig) => { %>
          <div class="sig-item" data-signature-id="<%= sig.id %>" data-signature-data="<%= sig.signature_data %>">
            <img src="<%= sig.signature_data %>" alt="<%= sig.signer_name %>" />
            <div class="sig-name"><%= sig.signer_name %></div>
          </div>
        <% }) %>
      <% } %>
    </div>
    <div class="pdf-viewer-area" id="pdf-viewer">
      <div class="text-white">Loading PDF...</div>
    </div>
  </div>
</div>

<input type="hidden" id="pdf-filename" value="<%= filename %>" />

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script>
  pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
</script>
<%- include('../partials/scripts') %>
<script src="/js/pdf-editor.js"></script>
