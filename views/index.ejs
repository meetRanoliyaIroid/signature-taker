<%- include('partials/head') %>

<nav class="navbar navbar-dark bg-dark mb-4">
  <div class="container">
    <a class="navbar-brand" href="/">Signature Taker</a>
    <a href="/signatures" class="btn btn-outline-light btn-sm">View All Signatures</a>
  </div>
</nav>

<div class="container">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card shadow">
        <div class="card-header bg-primary text-white">
          <h4 class="mb-0">Draw Your Signature</h4>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <label for="signer-name" class="form-label">Full Name <span class="text-danger">*</span></label>
            <input
              type="text"
              class="form-control"
              id="signer-name"
              placeholder="Enter your full name"
              required
            />
          </div>

          <div class="mb-3">
            <label for="signer-email" class="form-label">Email (Optional)</label>
            <input
              type="email"
              class="form-control"
              id="signer-email"
              placeholder="Enter your email"
            />
          </div>

          <div class="mb-3">
            <label class="form-label">Signature</label>
            <div class="signature-wrapper">
              <canvas id="signature-canvas"></canvas>
            </div>
          </div>

          <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-secondary" id="clear-btn">Clear</button>
            <button type="button" class="btn btn-outline-warning" id="undo-btn">Undo</button>
            <button type="button" class="btn btn-success ms-auto" id="save-btn">Save Signature</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/signature_pad@5.0.4/dist/signature_pad.umd.min.js"></script>
<%- include('partials/scripts') %>
<script src="/js/app.js"></script>
